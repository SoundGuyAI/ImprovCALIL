{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Israeli Improv Organizers Schema",
  "description": "Schema representing an array of Israeli improv organizer records",
  "type": "array",
  "items": {
    "$ref": "#/definitions/organizer"
  },
  "definitions": {
    "organizer": {
      "type": "object",
      "properties": {
        "name": {
          "$ref": "#/definitions/localizedString",
          "description": "The localized name of the organizer"
        },
        "type": {
          "type": "string",
          "enum": ["Group", "School", "Theater", "Other"],
          "description": "The category of the organizer"
        },
        "description": {
          "$ref": "#/definitions/localizedString",
          "description": "A localized description of the organizer's activities"
        },
        "region": {
          "type": "string",
          "enum": ["Tel-Aviv", "Jerusalem", "Beer-Sheva", "Haifa", "Hasharon", "Other areas"],
          "description": "The primary region where the organizer operates"
        },
        "languages": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["he", "en"]
          },
          "minItems": 1,
          "uniqueItems": true,
          "description": "Languages supported/used by the organizer"
        },
        "logoUrl": {
          "type": "string",
          "format": "uri",
          "description": "Optional URL to the organizer's logo or image"
        },
        "links": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "format": "uri",
                "description": "The destination URL"
              },
              "type": {
                "type": "string",
                "enum": [
                  "Website",
                  "Facebook",
                  "Facebook event",
                  "WhatsApp group",
                  "Instagram",
                  "Other"
                ],
                "description": "The type of the link"
              },
              "label": {
                "type": "string",
                "description": "Optional human-readable label for the link"
              }
            },
            "required": ["url", "type"],
            "additionalProperties": false
          },
          "description": "A list of typed links associated with the organizer"
        }
      },
      "required": ["name", "type", "description", "region", "languages"],
      "additionalProperties": false
    },
    "localizedString": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "properties": {
          "locale": {
            "type": "string",
            "enum": ["en", "he"]
          },
          "value": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["locale", "value"],
        "additionalProperties": false
      }
    }
  }
}
