rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user is admin via trusted custom claims.
    function isAdmin() {
      return isAuthenticated() && request.auth.token.isAdmin == true;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidContact(contact) {
      return contact is map &&
        contact.keys().hasOnly(['email', 'phone']) &&
        contact.email is string &&
        contact.email.size() <= 320 &&
        (!('phone' in contact) || contact.phone is string && contact.phone.size() <= 40);
    }

    function isValidSubmissionCreate() {
      return request.resource.data.keys().hasOnly([
        'type',
        'status',
        'source',
        'data',
        'links',
        'createdAt',
        'submitterContact',
        'targetDocumentId'
      ]) &&
        request.resource.data.type in ['event', 'organizer'] &&
        request.resource.data.status == 'pending' &&
        request.resource.data.source is string &&
        request.resource.data.source.size() <= 40 &&
        request.resource.data.data is map &&
        request.resource.data.createdAt is number &&
        isValidContact(request.resource.data.submitterContact) &&
        (!('links' in request.resource.data) ||
          request.resource.data.links is list && request.resource.data.links.size() <= 10) &&
        (!('targetDocumentId' in request.resource.data) ||
          request.resource.data.targetDocumentId is string && request.resource.data.targetDocumentId.size() <= 100) &&
        (
        isAuthenticated() ||
        !exists(/databases/$(database)/documents/config/submissions) ||
        get(/databases/$(database)/documents/config/submissions).data.allowAnonymous == true
        );
    }

    function isValidSubscriberCreate() {
      return request.resource.data.keys().hasOnly(['email', 'createdAt']) &&
        request.resource.data.email is string &&
        request.resource.data.email.size() <= 320 &&
        (!('createdAt' in request.resource.data) || request.resource.data.createdAt is number);
    }

    // Events rules
    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Organizers rules
    match /organizers/{organizerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Links rules
    match /links/{linkId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Submissions rules
    match /submissions/{submissionId} {
      allow create: if isValidSubmissionCreate();
      allow read, write: if isAdmin();
    }

    // Subscribers rules
    match /subscribers/{subscriberId} {
      allow create: if isValidSubscriberCreate();
      allow read, write: if isAdmin();
    }

    // Users rules
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow write: if isAdmin();
    }

    // Config rules
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
